{
    "name": "Solana Explore",
    "image": "solidstaker/anchor-s_ubu22_rjs:explore@sha256:c1394912ea5f3143801ee6c2b0aef05284fb0609415090eeeae643a51c7e68a4",
    "customizations": {
        "vscode": {
            "settings": {
                "editor.formatOnSave": true,
                "terminal.integrated.defaultProfile.linux": "bash",
                "terminal.integrated.profiles.linux": {
                    "bash": {
                        "path": "/bin/bash"
                    },
                    "PowerShell": {
                        "path": "/usr/bin/pwsh",
                        "icon": "terminal-powershell"
                    }
                }
            },
            "extensions": [
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "richie5um2.vscode-sort-json",
                "vscode-json-editor.vscode-json-editor",
                "redhat.vscode-yaml",
                "tamasfe.even-better-toml",
                "rust-lang.rust-analyzer",
                "patryk.rust-extension-pack",
                "serayuzgur.crates",
                "ms-vscode.cpptools",
                "christian-kohler.npm-intellisense",
                "ms-dotnettools.vscode-dotnet-runtime",
                "ms-azuretools.vscode-docker",
                "eamodio.gitlens",
                "mhutchie.git-graph",
                "ms-vscode.remote-explorer",
                "ms-vscode-remote.vscode-remote-extensionpack",
                "vscode-icons-team.vscode-icons",
                "mechatroner.rainbow-csv",
                "visualstudioexptteam.vscodeintellicode"
            ]
        }
    },
   "postCreateCommand": [
    "bash -c \"CI=1 curl --proto '=https' --tlsv1.2 -sSfL https://solana-install.solana.workers.dev | bash\""
   ],
    "workspaceFolder": "/usr/src/projectSpace",
    "remoteUser": "devuser",
    "mounts": [
        "source=v01_DATA,target=/usr/src/projectSpace,type=volume"
    ],
    "postStartCommand": "git config --global user.name '${localEnv:GIT_USERNAME}' && git config --global user.email '${localEnv:GIT_EMAIL}'",
    "forwardPorts": [3000],
    "shutdownAction": "stopContainer"
}